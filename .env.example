# Folia Wiki Farm — Environment Variables
# Copy this to .env and adjust values for your deployment.

# Django
SECRET_KEY=change-this-to-a-random-string
DEBUG=1
ALLOWED_HOSTS=*

# Database
DB_PASSWORD=folia_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Meilisearch
MEILI_KEY=folia_dev_key

# MinIO (S3-compatible storage)
MINIO_USER=folia
MINIO_PASSWORD=folia_dev

# Folia
FOLIA_DOMAIN=folia.localhost

# Frontend
VITE_API_URL=http://localhost:8000
